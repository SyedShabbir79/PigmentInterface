{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Domain": "yourdomain.onmicrosoft.com",
    "TenantId": "YOUR_TENANT_ID",
    "ClientId": "YOUR_CLIENT_ID",
    "Audience": "api://YOUR_CLIENT_ID"
  },

  "Authorization": {
    "AllowedGroups": [
      "YOUR_ENTRA_GROUP_OBJECT_ID"
    ]
  },

  "ConnectionStrings": {
    "MiddlewareDb": "Server=tcp:your-middleware-server.database.windows.net,1433;Database=MiddlewareDB;Authentication=Active Directory Default;Encrypt=True;"
  },

  "AzureStorage": {
    "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net",
    "ContainerName": "pigment-hr-files",
    "BlobPrefix": "pigment-hr"
  },

  "Sftp": {
    "Host": "",
    "Port": "22",
    "Username": "",
    "Password": "",
    "RemotePath": "/"
  },

  "Cors": {
    "AllowedOrigins": []
  },

  "ApplicationInsights": {
    "ConnectionString": ""
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Pigment.API.Authorization.GroupAuthorizationHandler": "Debug"
    }
  },

  "AllowedHosts": "*"
}
